{% extends "layouts/default.njk" %}

{% block back_link %}
    {% include "partials/back_link.njk" %}
{% endblock %}

{% block main_content %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <span class="govuk-caption-l">{{companyName}} ({{companyNumber}})</span>
            <h1 class="govuk-heading-l govuk-!-margin-bottom-6">
                {{lang.this_company_has_already_been_added}}
            </h1>
            <p class="govuk-body">
                {{lang.you_are_already_digitally_authorised}}
            </p>
            <p class="govuk-body">
                <a class="govuk-button" href="{{landingPageUrl}}">{{lang.go_to_your_companies}}</a>
            </p>
            <p class="govuk-body">
                <a class="govuk-link" href="{{addCompanyUrl}}">{{lang.go_back_enter_different_company_number}}</a>
            </p>
        </div>
    </div>
{% endblock %}